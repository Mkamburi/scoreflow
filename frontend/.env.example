# ScoreFlow frontend — copy for local dev:
#   cp .env.example .env
#
# Production (Vercel, Netlify, etc.): set these in the host's Environment Variables UI.
# Do not commit .env.

# Flat.io Embed App ID — https://flat.io/developers/apps
# Add your production site URL to the app's allowed domains.
VITE_FLAT_APP_ID=

# API base URL (leave unset in dev — Vite proxies /api to http://127.0.0.1:8000)
# Production example:
# VITE_API_BASE_URL=https://your-api.onrender.com

# Optional upload limit hint for client validation (should match backend MAX_UPLOAD_SIZE_MB)
# VITE_MAX_UPLOAD_SIZE_MB=50

# ScoreFlow backend — copy to .env for local dev:
#   cp .env.example .env
#
# Production: do NOT commit .env. Set these same names in your host's
# Environment Variables / Secrets panel (Render, Railway, Fly.io, etc.).

UPLOAD_DIR=/tmp/scoreflow/uploads
STEMS_DIR=/tmp/scoreflow/stems
MIDI_DIR=/tmp/scoreflow/midi
MAX_UPLOAD_SIZE_MB=50
PIPELINE_MAX_AUDIO_SECONDS=120
SEPARATION_TIMEOUT_SEC=1800
TRANSCRIPTION_TIMEOUT_SEC=1800
NOTATION_MIN_NOTE_QUARTER_LENGTH=0.25
NOTATION_DEDUPE_GRID_QUARTER_LENGTH=0.5
NOTATION_MAX_NOTES_PER_BAR=8
NOTATION_MAX_BARS=64
NOTATION_MELODY_FOCUS=true
NOTATION_MELODY_MAX_BARS=32
NOTATION_MELODY_MIN_VELOCITY=45
ENABLE_AI_COMPLETION=true

# Comma-separated frontend URLs allowed to call the API (required in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional — only if using GPT-style harmony (style=gpt); rule-based bass works without this
# OPENAI_API_KEY=
